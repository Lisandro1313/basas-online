# --- Firebase: config pública del cliente ---------------------------------
# Firebase Console > Project settings > General > Tus apps > App web.
# No son secretos: el acceso lo controlan las reglas de firestore.rules.
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_PROJECT_ID=basas-online
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=basas-online.firebaseapp.com

# --- Firebase Admin: credenciales de servidor -----------------------------
# Firebase Console > Project settings > Service accounts > Generar nueva clave
# privada. Del JSON que descarga salen estos tres valores.
# OJO: la private key salta TODAS las reglas. Nunca con prefijo NEXT_PUBLIC_.
FIREBASE_PROJECT_ID=basas-online
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@basas-online.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
